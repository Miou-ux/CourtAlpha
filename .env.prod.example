# PROD — copier vers /opt/courtalpha/.env (chmod 600)
BETTINGHUD_ROOT=/opt/bettinghud
BETTINGHUD_ENV=prod
BETTINGHUD_HEADLESS=1

API_HOST=127.0.0.1
API_PORT=8000

# Same-origin via nginx :80 — CORS inutile en prod
CORS_ORIGINS=

BETTINGHUD_WEB_AUTH_REQUIRED=1
BETTINGHUD_WEB_REGISTRATION_OPEN=1

# Acquisition — canal Telegram public (build frontend + crons)
TELEGRAM_CHANNEL_ID=@courtalpha_1day1pick
TELEGRAM_CHANNEL_ENABLED=1
COURTALPHA_PUBLIC_URL=https://courtalpha.tech
VITE_TELEGRAM_CHANNEL_URL=https://t.me/courtalpha_1day1pick
